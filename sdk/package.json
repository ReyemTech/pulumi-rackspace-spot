{
  "name": "@reyemtech/pulumi-rackspace-spot",
  "version": "0.2.1",
  "description": "Pulumi provider for Rackspace Spot — cloudspaces, node pools, kubeconfig",
  "main": "bin/index.js",
  "types": "bin/index.d.ts",
  "files": [
    "bin/",
    "cmd/",
    "types/"
  ],
  "bin": {
    "pulumi-resource-rackspace-spot": "cmd/pulumi-resource-rackspace-spot.js"
  },
  "scripts": {
    "build": "tsc && rm -rf cmd/provider && cp -r ../provider/bin cmd/provider",
    "postinstall": "node cmd/install-plugin.js"
  },
  "pulumi": {
    "resource": true,
    "name": "rackspace-spot"
  },
  "keywords": [
    "pulumi",
    "rackspace",
    "spot",
    "kubernetes",
    "cloud"
  ],
  "author": "ReyemTech <mario@reyem.tech>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReyemTech/pulumi-rackspace-spot.git"
  },
  "peerDependencies": {
    "@pulumi/pulumi": "^3.0.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "^3.142.0"
  }
}
